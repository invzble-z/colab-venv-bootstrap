# ============================================================
# colab/config.env — config tập trung cho colab-venv-bootstrap
# ============================================================
# File này được `source` bởi bootstrap_env.sh + đọc bởi notebook.
# CÚ PHÁP: KEY="value" (shell-style, KHÔNG có space quanh dấu =)
# Comment dùng #. Multiline KHÔNG hỗ trợ.
#
# Xem thêm: colab/bootstrap/docs/config_reference.md

# ============================================================
# 1. Project identity (BẮT BUỘC)
# ============================================================

# Slug của project, dùng để derive paths. Phải khớp với tên repo trên Drive.
PROJECT_SLUG="my_project"

# Drive root chứa project. Mặc định: /content/drive/MyDrive
# Repo sẽ ở $BASE_ROOT/$PROJECT_SLUG
# Artifacts sẽ ở $BASE_ROOT/${PROJECT_SLUG}_colab
BASE_ROOT="/content/drive/MyDrive"

# ============================================================
# 2. Python
# ============================================================

# Binary Python để tạo venv. Mặc định: python3 (Colab default).
# Nếu cần Python 3.10/3.11 (vd torch < 2.0): set "python3.10" + APT_PYTHON_PACKAGES bên dưới.
PYTHON_BIN="python3"

# APT packages để cài python phiên bản cụ thể (nếu cần).
# Để rỗng nếu dùng Python default của Colab.
# Ví dụ: "python3.10 python3.10-venv python3.10-dev"
APT_PYTHON_PACKAGES=""

# APT packages bổ sung (espeak-ng, libsndfile1, ffmpeg, ...).
APT_EXTRA_PACKAGES=""

# ============================================================
# 3. Torch
# ============================================================

# Có cài torch không? 1 = có, 0 = bỏ qua.
INSTALL_TORCH=1

# Wheel index URL cho torch + CUDA version.
# - cu121 (default, dùng cho Colab T4 hiện tại + torch 2.x)
# - cu117 (cho torch 1.13.x)
# - cu118 / cu126 / ...
TORCH_INDEX_URL="https://download.pytorch.org/whl/cu121"

# Flag pip để dùng torch index. Mặc định --extra-index-url (fallback to PyPI cho deps khác).
# Đổi --index-url nếu muốn chỉ dùng torch index (vd torch nightly).
TORCH_INDEX_FLAG="--extra-index-url"

# Nếu torch được pin trong file riêng (vd requirements-pytorch.txt), điền path tương đối từ repo root.
# Để rỗng → cài "torch torchaudio" default version từ TORCH_INDEX_URL.
TORCH_REQUIREMENTS_FILE=""

# ============================================================
# 4. Requirements chính
# ============================================================

# Path tương đối từ repo root tới requirements.txt.
# Ví dụ: "requirements.txt" hoặc "server/requirements.txt"
REQUIREMENTS_FILE="requirements.txt"

# Packages cài TRƯỚC requirements.txt (vd pin pip/setuptools nếu lightning < 1.8 yêu cầu).
# Mặc định: "pip setuptools wheel"
PIP_PRE_INSTALL="pip setuptools wheel"

# ============================================================
# 5. Reuse check
# ============================================================

# Sau khi cài xong, bootstrap script verify các module sau import được
# (cũng dùng để quyết định "có cần rebuild" khi runtime mới).
# Space-separated. Tham khảo examples/ cho danh sách phù hợp.
REUSE_CHECK_MODULES="torch"

# ============================================================
# 6. Snapshot
# ============================================================

# Lưu snapshot venv lên Drive sau khi cài xong? 1 = có (recommended), 0 = không.
ENABLE_VENV_SNAPSHOT=1

# Force rebuild venv ngay cả khi fingerprint match? 1 = có.
# Dùng khi snapshot bị corrupt hoặc muốn cài lại từ đầu.
FORCE_REINSTALL=0

# ============================================================
# 7. GitHub clone (chỉ cần cho 00_clone_repo.ipynb)
# ============================================================

# Repo URL trên GitHub (không có token).
GITHUB_REPO_URL="https://github.com/<user>/<repo>.git"

# Branch để clone. Mặc định: main
GITHUB_BRANCH="main"

# Sparse checkout — nếu chỉ cần subset folder. Space-separated.
# Để rỗng cho full checkout. Ví dụ: "server colab"
GITHUB_SPARSE_CHECKOUT=""

# ============================================================
# 8. Override paths (advanced, hiếm dùng)
# ============================================================

# Tất cả các path sau đều derive từ BASE_ROOT + PROJECT_SLUG.
# Chỉ uncomment nếu cần custom (vd dataset external, multi-repo layout).
#
# REPO_DIR="$BASE_ROOT/$PROJECT_SLUG"
# DRIVE_ROOT="$BASE_ROOT/${PROJECT_SLUG}_colab"
# VENV_DIR="/content/venvs/$PROJECT_SLUG"
# PIP_CACHE_DIR="$DRIVE_ROOT/cache/pip"
# HF_CACHE_DIR="$DRIVE_ROOT/cache/hf"
