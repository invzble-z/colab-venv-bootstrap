#!/usr/bin/env bash
# ============================================================
# post_install.sh — Project-specific steps SAU khi pip install
# ============================================================
# Hook này được gọi bởi bootstrap_env.sh sau khi cài requirements.
# Dùng để: clone repo phụ, build C extension, swap package version, ...
#
# Env vars có sẵn (đã export bởi bootstrap):
#   VENV_DIR            — đường dẫn venv (vd /content/venvs/<slug>)
#   REPO_DIR            — đường dẫn project repo trên Drive
#   DRIVE_ROOT          — artifacts root trên Drive
#   PIP_CACHE_DIR       — pip cache dir
#   HF_CACHE_DIR        — HuggingFace cache dir
#   COLAB_DIR           — <project>/colab
#   SUBMODULE_ROOT      — <project>/colab/bootstrap
#   PROJECT_SLUG, BASE_ROOT
#
# Để enable hook:
#   1. Rename file thành post_install.sh (bỏ đuôi .example)
#   2. chmod +x post_install.sh (optional — bootstrap dùng `bash` để chạy)
# ============================================================

set -euo pipefail

VENV_PY="$VENV_DIR/bin/python"

