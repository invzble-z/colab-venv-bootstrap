# ============================================================
# config.env — FastAPI server + Cloudflare tunnel
# ============================================================

# === Project identity ===
PROJECT_SLUG="GradProject"
BASE_ROOT="/content/drive/MyDrive/VKU/Graduation_project"

# === Python ===
# Dùng Python default của Colab (torch 2.x có wheel cho 3.10/3.11/3.12).
PYTHON_BIN="python3"
APT_PYTHON_PACKAGES=""
APT_EXTRA_PACKAGES=""

# === Torch ===
INSTALL_TORCH=1
TORCH_INDEX_URL="https://download.pytorch.org/whl/cu121"
# --index-url thay vì --extra-index-url để force dùng torch wheel index cho torch.
# (Dùng extra-index-url cũng OK, đổi nếu pip resolver chậm.)
TORCH_INDEX_FLAG="--index-url"
TORCH_REQUIREMENTS_FILE=""

# === Main requirements ===
REQUIREMENTS_FILE="server/requirements.txt"
PIP_PRE_INSTALL="pip setuptools wheel"

# === Reuse check ===
# Verify cả module thường + onnxruntime CUDA (qua sample import trong verify_env.py).
# Để check sâu hơn (CUDAExecutionProvider available), viết colab/hooks/verify_extra.sh.
REUSE_CHECK_MODULES="torch fastapi faster_whisper onnxruntime"

# === Snapshot ===
ENABLE_VENV_SNAPSHOT=1
FORCE_REINSTALL=0

# === GitHub ===
GITHUB_REPO_URL="https://github.com/<your-user>/GradProject.git"
GITHUB_BRANCH="main"
GITHUB_SPARSE_CHECKOUT="server colab"
