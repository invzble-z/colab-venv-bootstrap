# ============================================================
# config.env — Piper TTS fine-tuning (cross-gender female→male VN)
# ============================================================

# === Project identity ===
PROJECT_SLUG="piper_vi_vais1000_finetuning"
BASE_ROOT="/content/drive/MyDrive/VKU/Graduation_project"

# === Python ===
# Cần Python 3.10 vì torch 1.13.1 không có wheel cho 3.12 (Colab default 2026).
PYTHON_BIN="python3.10"
APT_PYTHON_PACKAGES="python3.10 python3.10-venv python3.10-dev"
APT_EXTRA_PACKAGES="espeak-ng libsndfile1 build-essential pkg-config"

# === Torch ===
INSTALL_TORCH=1
TORCH_INDEX_URL="https://download.pytorch.org/whl/cu117"
TORCH_INDEX_FLAG="--extra-index-url"
TORCH_REQUIREMENTS_FILE="requirements-pytorch.txt"

# === Main requirements ===
REQUIREMENTS_FILE="requirements.txt"

# Pin pip<24.1 + setuptools<81 cho compat với pytorch-lightning 1.7.7.
# - pip 24.1+ refuse `torch (>=1.9.*)` syntax của lightning 1.7.7.
# - setuptools 81+ remove pkg_resources mà lightning vẫn import.
PIP_PRE_INSTALL="pip<24.1 setuptools<81 wheel"

# === Reuse check (verify modules import được sau cài) ===
REUSE_CHECK_MODULES="torch pytorch_lightning librosa piper_train"

# === Snapshot ===
ENABLE_VENV_SNAPSHOT=1
FORCE_REINSTALL=0

# === GitHub ===
GITHUB_REPO_URL="https://github.com/<your-user>/piper_vi_vais1000_finetuning.git"
GITHUB_BRANCH="main"
GITHUB_SPARSE_CHECKOUT=""
